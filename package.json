{
  "name": "legacy-apartment-monorepo",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "rm -rf apps/frontend/.next apps/admin/.next && turbo dev",
    "fix-dev": "rm -rf apps/frontend/.next apps/admin/.next && turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.15.3"
}
