generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  role      String   @default("secretary")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("announcement")
}

model Resident {
  id               Int               @id @default(autoincrement())
  avatar           String?
  name             String
  residence        String
  phone_no         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  monthlyRate      Float             @default(1000)
  monthlyPayments  MonthlyPayment[]
  securityPayments SecurityPayment[]

  @@map("resident")
}

model MonthlyPayment {
  id          Int       @id @default(autoincrement())
  residentId  Int
  month       Int
  year        Int
  status      Int       @default(0)
  amount      Float     @default(0)
  paymentType String?   // "Cash" or "Online"
  paymentDate DateTime?
  lateFee     Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  resident    Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@unique([residentId, month, year])
  @@map("monthly_payment")
}

model SecurityPayment {
  id          Int       @id @default(autoincrement())
  residentId  Int
  year        Int
  status      Int       @default(0)
  yearlyRate  Float     @default(0)
  amount      Float     @default(0)
  paymentType String?   // "Cash" or "Online"
  paymentDate DateTime?
  lateFee     Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  resident    Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@unique([residentId, year])
  @@map("security_payment")
}

model Setting {
  id               Int      @id @default(autoincrement())
  monthlyFee       Float    @default(1000)
  yearlyFee        Float    @default(5000)
  frontendPassword String   @default("")
  updatedAt        DateTime @updatedAt
  year             Int      @unique

  @@map("setting")
}

model Rule {
  id        Int      @id @default(autoincrement())
  category  String
  icon      String?
  rule      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rule")
}

model Complaint {
  id        Int      @id @default(autoincrement())
  name      String
  apartment String
  phone_no  String
  complaint String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("complaint")
}

model CommitteeMember {
  id        Int      @id @default(autoincrement())
  avatar    String?
  name      String
  residence String
  phone_no  String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("committee_member")
}

model Document {
  id          Int      @id @default(autoincrement())
  document    String
  fileName    String?
  date        DateTime
  description String?
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("document")
}

model GalleryEvent {
  id        Int            @id @default(autoincrement())
  name      String
  date      DateTime
  year      Int
  photos    GalleryPhoto[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("gallery_event")
}

model GalleryPhoto {
  id        Int          @id @default(autoincrement())
  eventId   Int
  src       String       @db.Text
  alt       String?
  className String?
  event     GalleryEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("gallery_photo")
}

